# .env.template - Jenkins CI/CD Configuration Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to Git!

# ========================================
# GitHub Configuration
# ========================================
GITHUB_CREDENTIAL_ID=github-credentials
# NOTE: Create this credential in Jenkins:
#   - Type: Username with password
#   - Username: WarunaUdara
#   - Password: Your GitHub Personal Access Token with 'repo' scope

# ========================================
# DockerHub Configuration
# ========================================
DOCKERHUB_USERNAME=warunaudara
DOCKERHUB_CREDENTIAL_ID=dockerhub-credentials
# NOTE: Create this credential in Jenkins:
#   - Type: Username with password
#   - Username: warunaudara
#   - Password: Your DockerHub password or access token

# ========================================
# GCP/GKE Configuration
# ========================================
GCP_PROJECT_ID=your-gcp-project-id
GKE_CLUSTER_NAME=todo-app-cluster
GKE_CLUSTER_ZONE=us-central1-a
GCP_CREDENTIAL_ID=gcp-service-account-key
# NOTE: Create this credential in Jenkins:
#   - Type: Secret file
#   - File: Your GCP service account JSON key

# ========================================
# ArgoCD Configuration
# ========================================
ARGOCD_SERVER=argocd.example.com
ARGOCD_CREDENTIAL_ID=argocd-auth-token

# ========================================
# Application Configuration
# ========================================
APP_PORT=8080
GIN_MODE=release
